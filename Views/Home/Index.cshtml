         let increment = 1;
         window.addSection = function(id) {
             if (!id) return;
             const selection = document.getElementById('sectionSelect');
             if (!selection) return console.warn('sectionSelect not found');
             const selectedIds = Array.from(selection.selectedOptions).map(o => o.value).filter(v => v);
             if (selectedIds.length === 0) return console.log('No questions selected for section');

             const container = document.getElementById('questionsList');
             if (!container) return console.error('questionsList not found');

             const firstId = selectedIds[0];
             const firstDef = (availableQuestions || []).find(q => (q.id && q.id === firstId) || (q.Id && q.Id === firstId));
             //sectionName = firstDef ? firstDef.Label || firstDef.label || `Section (${selectedIds.length} questions)` : `Section (${selectedIds.length} questions)`;
             sectionName = `Section ${increment++}`;
             console.log(increment);

             const sectionId = `section_${Date.now()}`;
             const section = document.createElement('div');
             section.className = 'mb-4 border rounded p-3 bg-light';
             section.id = sectionId;

             const header = document.createElement('div');
             header.className = 'd-flex justify-content-between align-items-center mb-2';
             const title = document.createElement('strong');
             title.textContent = sectionName;
             const removeSection = document.createElement('button');
             removeSection.type = 'button';
             removeSection.className = 'btn btn-sm btn-outline-danger';
             removeSection.textContent = 'Remove section';
             removeSection.addEventListener('click', () => {
                 for (let i = addedQuestions.length - 1; i >= 0; i--)
                 {
                     if (addedQuestions[i].sectionId === sectionId)
                     {
                         addedQuestions.splice(i, 1);
                     }
                 }
                 section.remove();
                 updateQuestionsPreview();
             });
             header.appendChild(title);
             header.appendChild(removeSection);
             section.appendChild(header);
             container.appendChild(section);

             const listHolder = document.createElement('div');
             listHolder.className = 'section-questions';
             section.appendChild(listHolder);

             container.appendChild(section);

             selectedIds.forEach(id => {
                 window.addQuestion(id);

                 const maybeLast = container.lastElementChild;
                 if (!maybeLast) return;

                 listHolder.appendChild(maybeLast);

                 const instanceId = maybeLast.dataset.instanceId;
                 if (instanceId)
                 {
                     const rec = addedQuestions.find(r => r.instanceId === instanceId);
                     if (rec) rec.sectionId = sectionId;
                 }
             });
             updateQuestionsPreview();
         };
         

         window.addQuestion = function(id) {
             if (!id) return;
             const def = availableQuestions.find(question => (question.id && question.id === id) || (question.Id && question.Id === id));
             if (!def) return;
             
             instanceCounter++;
             const container = document.getElementById('questionsList');
             if (!container)
             {
                 console.log("#questionsList not found");
                 return;
             }

             const wrapper = document.createElement('div');
             wrapper.className = 'mb-3 border rounded p-2';
             wrapper.dataset.defId = id;
             wrapper.dataset.instanceId = `instance_${instanceCounter}`;

             const questionRecord = {
                 id: id,
                 instanceId: wrapper.dataset.instanceId,
                 label: def.label ?? def.Label ?? 'Question',
                 target: def.target ?? def.Target ?? 'bio',
                 value: '',
                 values: []
             };

             //(window.addQuestion = window.addQuestion || []).push(questionRecord);
             
             // Label
             const label = document.createElement('label');
             label.className = 'form-label';
             label.textContent = questionRecord.label;
             wrapper.appendChild(label);
             
             // Helper to set target value and rerender preview
             function setTargetValue(value) {
                 if (def.target) {
                     // target names should match preview mapping: firstName, lastName, email, bio
                     answers[def.target] = value;
                     renderPreviewFromAnswers();
                 }
             }
             //console.log(def);
             // def.Type might be numeric (enum) or string depending on JSON serializer.
             const typeVal = (typeof def.Type === 'number') ? def.Type : (def.Type || '').toString().toLowerCase();
             const options = def.Questions || [];
             console.log(options);
             
             // Text
             if (typeVal === 0 || typeVal === 'text' || typeVal === 'Text'.toLowerCase()) {
                 const input = document.createElement('input');
                 input.className = 'form-control';
                 input.type = 'text';
                 input.placeholder = 'Type answer...';
                 input.addEventListener('input', e => setTargetValue(e.target.value));
                 wrapper.appendChild(input);
             }
             // Single select
             else if (typeVal === 1 || typeVal === 'singleselect' || typeVal === 'singleselect') {
                 const sel = document.createElement('select');
                 sel.className = 'form-select';
                 const opts = def.Questions || [];
                 sel.appendChild(new Option('-- choose --', ''));
                 opts.forEach(opt => sel.appendChild(new Option(opt, opt)));
                 sel.addEventListener('change', e => setTargetValue(e.target.value));
                 wrapper.appendChild(sel);
             }
             // Multi select (native multi)
             else if (typeVal === 2 || typeVal === 'multiselect' || typeVal === 'multiselect') {
                 const sel = document.createElement('select');
                 sel.className = 'form-select';
                 sel.multiple = true;
                 const opts = def.questions || [];
                 opts.forEach(opt => sel.appendChild(new Option(opt, opt)));
                 sel.addEventListener('change', () => {
                     const vals = Array.from(sel.selectedOptions).map(o => o.value);
                     setTargetValue(vals.join(', '));
                 });
                 wrapper.appendChild(sel);
             }
             // Checkbox list (each option a checkbox)
             else if (typeVal === 3 || typeVal === 'checkbox' || typeVal === 'Checkbox'.toLowerCase()) {
                 console.log(typeof typeVal, typeVal);
                 questionRecord.values = [];

                 //const options = def.questions || [];
                 options.forEach((option, i) => {
                     const chkWrap = document.createElement('div');
                     chkWrap.className = 'form-check';
                     const cb = document.createElement('input');
                     cb.className = 'form-check-input';
                     cb.type = 'Checkbox';
                     cb.value = option;
                     cb.id = `chk_${id}_${instanceCounter}_${i}`;
                     cb.addEventListener('change', () => {
                         const checked = Array.from(wrapper.querySelectorAll('input[type=checkbox]:checked')).map(i => i.value);
                         questionRecord.values = checked;
                         questionRecord.value = checked.join(', ');
                         updateQuestionsPreview();
                     });

                     const label = document.createElement('label');
                     label.className = 'form-check-label ms-1';
                     label.htmlFor = cb.id;
                     label.textContent = option;
                     chkWrap.appendChild(cb);
                     chkWrap.appendChild(label);
                     wrapper.appendChild(chkWrap);
                 });
             }
             else {
                 // fallback to text input
                 const input = document.createElement('input');
                 input.className = 'form-control';
                 input.type = 'text';
                 input.placeholder = 'Type answer...';
                 input.addEventListener('input', e => setTargetValue(e.target.value));
                 wrapper.appendChild(input);
             }
             
             // Remove button
             const remove = document.createElement('button');
             remove.type = 'button';
             remove.className = 'btn btn-sm btn-outline-danger mt-2';
             remove.textContent = 'Remove';
             remove.addEventListener('click', () => {
                 // optionally clear mapped value when removed:
                 if (def.target) {
                     // only clear if no other question is mapping to same target; simple approach: reset to server initial
                     if (def.target === 'firstName') answers.firstName = initialFirst;
                     if (def.target === 'lastName') answers.lastName = initialLast;
                     if (def.target === 'email') answers.email = initialEmail;
                     if (def.target === 'bio') answers.bio = '';
                     renderPreviewFromAnswers();
                 }
                 wrapper.remove();
             });
             wrapper.appendChild(remove);
             
             questionsList.appendChild(wrapper);
        };

