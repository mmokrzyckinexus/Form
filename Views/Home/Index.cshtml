@using Microsoft.Graph.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Home Page";
}
@model HomeIndexViewModel

@{
    var directReportsProjection = Model.AzureUser.DirectReports.Select(user => new
    {
        displayname = user.DisplayName,
        userPrincipalName = user.UserPrincipalName
    }) ?? Enumerable.Empty<object>();

    var directReportsJson = JsonSerializer.Serialize(directReportsProjection);
    var currentdirectReportGivenName = Model.AzureUser.User.GivenName ?? "";
    var currentdirectReportSurName = Model.AzureUser.User.Surname ?? "";
    var currentdirectReportEmail = Model.AzureUser.User.UserPrincipalName ?? "";
}

<div class="text-center mb-3">
    <h1 class="display-1">Welcome</h1>
    <p>Ask custom questions on the left. Answers map to fields on the preview form on the right (unsaved).</p>
</div>

<!--<component type="typeof(Form.Pages.FormBuilder)" render-mode="ServerPrerendered"
           param-DirectReportJason="@directReportsJson"
           param-UserGivenName="@currentdirectReportGivenName"
           param-UserSurname="@currentdirectReportSurName"
           param-UserEmail="@currentdirectReportEmail" />-->

<div class="row g-3" style="height:75vh;">
    <div class="col-md-5" style="overflow:auto;">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Questions</h5>

                <div class="mb-3">
                    <label class="form-label small">Form subject</label>
                    <div class="d-flex gap-3 align-items-center">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="formSubject" id="subjectSelf" value="self" checked>
                            <label class="form-check-label" for="subjectSelf">For me (@currentdirectReportGivenName @currentdirectReportSurName)</label>
                        </div>

                        @if ((Model.AzureUser.DirectReports ?? Enumerable.Empty<User>()).Any())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="formSubject" id="subjectDirect" value="direct">
                                <label class="form-check-label" for="subjectDirect">For a direct report</label>
                            </div>
                        }
                    </div>

                    @if ((Model.AzureUser.DirectReports ?? Enumerable.Empty<User>()).Any())
                    {
                        <select id="directReportSelect" class="form-select mt-2">
                            <option value="">-- choose direct report --</option>
                            @foreach (var directReport in Model.AzureUser.DirectReports ?? Enumerable.Empty<User>())
                            {
                                var email = directReport.UserPrincipalName ?? "";
                                <option value="@directReport.Id" data-display="@directReport.DisplayName" data-email="@email">@directReport.DisplayName (@(string.IsNullOrEmpty(email) ? "no-email" : email))</option>
                            }
                        </select>
                        <div class="form-text">Selecting a direct report will overwrite preview fields (local, unsaved).</div>
                    }
                    else
                    {
                        <select id="directReportSelect" class="form-select mt-2" disabled>
                            <option value="">-- choose direct report --</option>
                            @foreach (var directReport in Model.AzureUser.DirectReports ?? Enumerable.Empty<User>())
                            {
                                var email = directReport.UserPrincipalName ?? "";
                                <option value="@directReport.Id" data-display="@directReport.DisplayName" data-email="@email">@directReport.DisplayName (@(string.IsNullOrEmpty(email) ? "no-email" : email))</option>
                            }
                        </select>
                    }
                </div>

                <div id="questionsList" class="mb-3">
                    <!-- questions rendered here by JS -->
                </div>

                <div class="mb-3">
                    <label class="form-label">Add a question</label>
                    <select class="form-select" onchange="addQuestion(this.value)">
                        <option value="">-- Add a question --</option>
                        @foreach (var question in Model.AvailableQuestions)
                        {
                            <option value="@question.Id">@question.Label</option>
                        }
                    </select>
                </div>

                <button type="button" onclick="addQuestion()">Add</button>

                <div class="form-text mb-2">
                    Each question creates an answer input. Typing an answer will update the mapped preview field in realtime.
                </div>

                <div class="d-flex gap-2">
                    <button id="btnResetQuestions" class="btn btn-secondary">Reset questions</button>
                    <button id="btnClearAnswers" class="btn btn-outline-secondary">Clear answers</button>
                </div>
            </div>
        </div>

        <div class="col-md-7" style="overflow:auto;">
            <div id="previewWrapper" class="card d-none">
                <div class="card-header">
                    <strong>Live Preview (changes not saved)</strong>
                    <span id="unsavedDot" class="badge bg-warning text-dark ms-2">Unsaved</span>
                </div>
                <div class="card-body">
                    <h3 id="previewName"></h3>
                    <p><strong>Email:</strong> <span id="previewEmail"></span></p>
                    <p><strong>Summary:</strong></p>
                    <div id="previewBio" class="border rounded p-2" style="min-height:80px;"></div>
        
                    <div id="docPreview" class="mt-3" style="height:50vh;">
                        <!--<iframe id="wordFrame" src="@ViewBag.word" style="width:100%; height:100%; border:1px solid #ddd; display:none"></iframe>-->
                    </div>
                </div>
            </div>
        
            <div id="emptyPlaceholder" class="card text-muted text-center p-5">
                <div class="card-body">
                    <p class="mb-0">Preview will appear as you start typing in the form.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
         const firstName = document.getElementById('firstName');
         const lastName = document.getElementById('lastName');
         const email = document.getElementById('email');
         const bio = document.getElementById('bio');
         const previewWrapper = document.getElementById('previewWrapper');
         const emptyPlaceholder = document.getElementById('emptyPlaceholder');
         const previewName = document.getElementById('previewName');
         const previewEmail = document.getElementById('previewEmail');
         const previewBio = document.getElementById('previewBio');
         const wordFrame = document.getElementById('wordFrame');
         const includeIframe = document.getElementById('includeIframe');
         const btnSave = document.getElementById('btnSave');
         const btnReset = document.getElementById('btnReset');

        document.getElementById("directReportSelect").disabled = true;

         document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("subjectSelf").addEventListener("change", function () {
                if (this.checked)
                {
                    document.getElementById("directReportSelect").disabled = true;
                    document.getElementById("directReportSelect").selectedIndex = 0;
                }
                console.log("fired");
            })

            if (document.getElementById("subjectDirect"))
            {
                document.getElementById("subjectDirect").addEventListener("change", function () {
                    if (this.checked)
                    {
                       document.getElementById("directReportSelect").disabled = false;
                    }
                })
            }
         })

         // Flag to show preview only after first typing

         const availableQuestions = @Html.Raw(JsonSerializer.Serialize(Model.AvailableQuestions));

         function addQuestion()
         {
             const id = document.getElementById('questionSelect').value;
             const def = availableQuestions.find(question => question.id === id);
             if (!def) return;
         }

         let hasTyped = false;

         function showPreviewIfNeeded() {
             if (!hasTyped) {
                 previewWrapper.classList.remove('d-none');
                 emptyPlaceholder.classList.add('d-none');
                 hasTyped = true;
                 btnSave.disabled = false;
             }
         }

         function renderQuestion(def)
         {
             const container = document.getElementById('questionsList');
             
             let html = `<div class="mb-3">
                         <label class="form-label">${def.label}</label`;

             switch (def.type)
             {
                 case "text":
                     html += `<input class="form-control" name="Question[${def.id}].value"/>`;
                     break;
                 case "singleselect":
                     html += `<select class="form-select" name="Question[${def.id}].value">`;
                     break;
                 case "multiselect":
                     def.options.forEach(options => {
                         html += `<div class="form-check">
                                     <input class="form-check-input" type="checkbox" name="Questi[${def.id}].value"value="${options.value}" />
                                     <label class="form-check-label">${options}</label>
                                 </div>`;
                     });
                     break;
                 // add more types as needed
             }

             html += `<input type="hidden" name="Question[${def.id}].target" value="${def.target}" />`;
             container.insertAdjacentHTML('beforeend', html);
         }

         function updatePreview() {
             showPreviewIfNeeded();

             const f = firstName.value.trim();
             const l = lastName.value.trim();
             previewName.textContent = (f || l) ? `${f} ${l}`.trim() : 'No name provided';
             previewEmail.textContent = email.value.trim() || 'No email provided';
             previewBio.textContent = bio.value.trim() || '(empty)';

             if (includeIframe && includeIframe.checked) {
                 wordFrame.style.display = '';
             } else {
                 wordFrame.style.display = 'none';
             }
         }

         // Wire up events
         /*[firstName, lastName, email, bio].forEach(el => {
             el.addEventListener('input', updatePreview);
         });*/

         /*includeIframe.addEventListener('change', () => {
             if (hasTyped) updatePreview();
         });*/

         /*btnReset.addEventListener('click', () => {
             // reset to values that were prefilled initially (server-provided)
             firstName.value = '@(Model.AzureUser?.User?.GivenName ?? "")';
             lastName.value = '@(Model.AzureUser?.User?.Surname ?? "")';
             email.value = '@(Model.AzureUser?.User?.Mail ?? Model.AzureUser?.User?.UserPrincipalName ?? "")';
             bio.value = '';
             // hide preview until user types again
             previewWrapper.classList.add('d-none');
             emptyPlaceholder.classList.remove('d-none');
             hasTyped = false;
             btnSave.disabled = true;
             wordFrame.style.display = includeIframe.checked ? '' : 'none';
         });*/

         // Optional: Save handler (currently just disables state; implement server save if needed)
         /*btnSave.addEventListener('click', () => {
             btnSave.disabled = true;
             // show a quick saved indicator
             const savedBadge = document.createElement('span');
             savedBadge.className = 'badge bg-success ms-2';
             savedBadge.innerText = 'Saved (demo)';
             document.querySelector('#previewWrapper .card-header').appendChild(savedBadge);
             setTimeout(() => {
                 if (savedBadge.parentNode) savedBadge.remove();
                 btnSave.disabled = false;
             }, 1500);
         });*/

         // If the user has already prefilled values, show a preview when they focus or type
         // (don't show automatically on page load)
         // But if any value is non-empty and different from server-provided, show preview
         const initialFirst = '@(Model.AzureUser?.User?.GivenName ?? "")';
         const initialLast = '@(Model.AzureUser?.User?.Surname ?? "")';
         const initialEmail = '@(Model.AzureUser?.User?.Mail ?? Model.AzureUser?.User?.UserPrincipalName ?? "")';
         //if (firstName.value.trim() !== "" || lastName.value.trim() !== "" || email.value.trim() !== "") {
             // keep preview hidden until user interacts intentionally; uncomment to show immediately:
             // updatePreview();
         //}
    </script>
}

<div style="display:flex; height:90vh; gap:12px;">
    <h2>Name: @(Model.AzureUser.User.GivenName)</h2>
    @if (Model.AzureUser.Manager is Microsoft.Graph.Models.User user)
    {
        <h2>Name: @(user.DisplayName), upn: @(user.UserPrincipalName)</h2>
    }
    else if (Model.AzureUser.Manager is OrgContact oc)
    {
        <h2>NameOC: @(oc.DisplayName), @(oc.Mail)</h2>
    }
    else
    {
        <p>Manager is not a user or org contact.</p>
    }

    <ol>
        @foreach (var directReport in Model.AzureUser.DirectReports)
        {
            if (directReport is Microsoft.Graph.Models.User drUser)
            {
                <li style="color: black;">Name: @(drUser.DisplayName), upn: @(drUser.UserPrincipalName)</li>
            }
            else
            {
                <li>Direct report is not a user or org contact.</li>
            }
        }
    </ol>
</div>