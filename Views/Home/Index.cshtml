@using Microsoft.Graph.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Home Page";
}
@model Form.Models.AzureUserViewModel

@{
    var directReportsProjection = Model.DirectReports.Select(user => new
    {
        displayname = user.DisplayName,
        userPrincipalName = user.UserPrincipalName
    }) ?? Enumerable.Empty<object>();

    var directReportsJson = JsonSerializer.Serialize(directReportsProjection);
    var currentdirectReportGivenName = Model.User.GivenName ?? "";
    var currentdirectReportSurName = Model.User.Surname ?? "";
    var currentdirectReportEmail = Model.User.UserPrincipalName ?? "";
}

<div class="text-center mb-3">
    <h1 class="display-1">Welcome</h1>
    <p>Ask custom questions on the left. Answers map to fields on the preview form on the right (unsaved).</p>
</div>

<div class="row g-3" style="height:75vh;">
    <div class="col-md-5" style="overflow:auto;">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Questions</h5>

                <div class="mb-3">
                    <label class="form-label small">Form subject</label>
                    <div class="d-flex gap-3 align-items-center">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="formSubject" id="subjectSelf" value="self" checked>
                            <label class="form-check-label" for="subjectSelf">For me (@currentdirectReportGivenName @currentdirectReportSurName)</label>
                        </div>

                        @if ((Model.DirectReports ?? Enumerable.Empty<User>()).Any())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="formSubject" id="subjectDirect" value="direct">
                                <label class="form-check-label" for="subjectDirect">For a direct report</label>
                            </div>
                        }
                    </div>

                    @if ((Model.DirectReports ?? Enumerable.Empty<User>()).Any())
                    {
                        <select id="directReportSelect" class="form-select mt-2">
                            <option value="">-- choose direct report --</option>
                            @foreach (var directReport in Model.DirectReports ?? Enumerable.Empty<User>())
                            {
                                var email = directReport.UserPrincipalName ?? "";
                                <option value="@directReport.Id" data-display="@directReport.DisplayName" data-email="@email">@directReport.DisplayName (@(string.IsNullOrEmpty(email) ? "no-email" : email))</option>
                            }
                        </select>
                        <div class="form-text">Selecting a direct report will overwrite preview fields (local, unsaved).</div>
                    }
                    else
                    {
                        <select id="directReportSelect" class="form-select mt-2" disabled>
                            <!--<option value="">-- choose direct report --</option>-->
                            @{var email = Model.User.UserPrincipalName ?? "";}
                            <option value="@Model.User.Id" data-display="@Model.User.DisplayName" data-email="@email">@Model.User.DisplayName (@(string.IsNullOrEmpty(email) ? "no-email" : email))</option>
                        </select>
                    }
                </div>

                <div id="questionsList" class="mb-3">
                    <!-- questions rendered here by JS -->
                </div>

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-5">
                        <label class="form-label small">Question label</label>
                        <input id="newQuestionLabel" class="form-control" placeholder="e.g. What is your preferred name?" />
                    </div>
                    <div class="col-5">
                        <label class="form-label small">Map to</label>
                        <select id="newQuestionTarget" class="form-select">
                            <option value="firstName">Preview: First name</option>
                            <option value="lastName">Preview: Last name</option>
                            <option value="email">Preview: Email</option>
                            <option value="bio">Preview: Summary / Notes</option>
                        </select>
                    </div>
                    <div class="col-2">
                        <button id="btnAddQuestion" class="btn btn-primary w-100">Add</button>
                    </div>
                </div>

                <div class="form-text mb-2">
                    Each question creates an answer input. Typing an answer will update the mapped preview field in realtime.
                </div>

                <div class="d-flex gap-2">
                    <button id="btnResetQuestions" class="btn btn-secondary">Reset questions</button>
                    <button id="btnClearAnswers" class="btn btn-outline-secondary">Clear answers</button>

                    <button class="btn btn-primary ms-auto" type="button" data-bs-toggle="offcanvas" data-bs-target="#previewOffcanvas" aria-controls="previewOffcanvas">Preview</button>
                </div>
            </div>
        </div>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="previewOffcanvas" aria-labelledby="previewOffcanvasLabel" style="width:520px;">
        <div class="offcanvas-header">
            <h5 id="previewOffcanvasLabel">Preview (server)</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column" id="previewOffcanvasBody">
            <!-- server preview will be injected here -->
            <div class="text-muted mb-3">Click Preview to load server-rendered preview. Use Save to persist, or Cancel to close.</div>

            <div id="previewOffcanvasFooter" class="mt-auto d-flex gap-2">
                <input id="saveFilename" class="form-control form-control-sm" placeholder="File name (optional)" />
                <button id="btnSaveToDrive" class="btn btn-success">Save</button>
                <button id="btnCancelPreview" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">Cancel</button>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        (function () {
            // existing client code to build questions, subject, direct report selection...
            // (keep your previous initialization code)
            const directReports = @Html.Raw(directReportsJson);

            // state mirrors server
            let questions = []; // keep in sync with your UI
            let currentSubject = 'self';
            let selectedDirectReport = null;

            // helper to gather payload to send to server for preview/save
            function buildPayload() {
                return {
                    subject: currentSubject,
                    directReportId: selectedDirectReport ? selectedDirectReport.id : null,
                    questions: questions.map(q => ({ label: q.label, target: q.target, value: q.value })),
                    filename: document.getElementById('saveFilename')?.value
                };
            }

            // Wire Preview button (already exists in your UI as btnPreview)
            const btnPreview = document.getElementById('btnPreview');
            const previewOffcanvasBody = document.getElementById('previewOffcanvasBody');

            async function fetchServerPreview() {
                const payload = buildPayload();

                try {
                    const res = await fetch('/Home/Preview', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) {
                        const txt = await res.text();
                        console.error('Preview failed', res.status, txt);
                        alert('Preview generation failed.');
                        return;
                    }

                    const html = await res.text();
                    // inject the preview HTML (keep the footer controls visible)
                    // replace only the top portion of previewOffcanvasBody, keep footer
                    const footer = document.getElementById('previewOffcanvasFooter');
                    previewOffcanvasBody.innerHTML = html;
                    previewOffcanvasBody.appendChild(footer);

                    const offcanvasEl = document.getElementById('previewOffcanvas');
                    const offcanvas = new bootstrap.Offcanvas(offcanvasEl);
                    offcanvas.show();
                } catch (err) {
                    console.error(err);
                    alert('Preview request failed (network).');
                }
            }

            if (btnPreview) btnPreview.addEventListener('click', () => fetchServerPreview());

            // Save button inside offcanvas
            const btnSaveToDrive = document.getElementById('btnSaveToDrive');
            if (btnSaveToDrive) {
                btnSaveToDrive.addEventListener('click', async () => {
                    const payload = buildPayload();
                    try {
                        const res = await fetch('/Home/Save', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });

                        const json = await res.json();
                        if (!res.ok || !json?.success) {
                            console.error('Save failed', json);
                            alert('Save failed.');
                            return;
                        }

                        // show success and link if available
                        const successMsg = document.createElement('div');
                        successMsg.className = 'alert alert-success mt-2';
                        successMsg.innerHTML = 'Saved successfully. ' + (json.webUrl ? `<a target="_blank" href="${json.webUrl}">Open file</a>` : '');
                        // append to offcanvas body (or replace)
                        document.getElementById('previewOffcanvasBody').appendChild(successMsg);

                        // optionally disable Save to prevent duplicates
                        btnSaveToDrive.disabled = true;
                    } catch (err) {
                        console.error(err);
                        alert('Save request failed (network).');
                    }
                });
            }

            // Cancel button simply closes the offcanvas (Bootstrap data attribute handles it)

            // NOTE: keep your existing question UI code to push/pop `questions`, set `currentSubject`, and set `selectedDirectReport`.
            // The buildPayload() function reads from those variables.
    })();
    </script>
}

<div style="display:flex; height:90vh; gap:12px;">
    <h2>Name: @(Model.User.GivenName)</h2>
    @if (Model.Manager is Microsoft.Graph.Models.User user)
    {
        <h2>Name: @(user.DisplayName), upn: @(user.UserPrincipalName)</h2>
    }
    else if (Model.Manager is OrgContact oc)
    {
        <h2>NameOC: @(oc.DisplayName), @(oc.Mail)</h2>
    }
    else
    {
        <p>Manager is not a user or org contact.</p>
    }

    <ol>
        @foreach (var directReport in Model.DirectReports)
        {
            if (directReport is Microsoft.Graph.Models.User drUser)
            {
                <li style="color: black;">Name: @(drUser.DisplayName), upn: @(drUser.UserPrincipalName)</li>
            }
            else
            {
                <li>Direct report is not a user or org contact.</li>
            }
        }
    </ol>
</div>