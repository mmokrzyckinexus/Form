@using System.Text.Json
@inject IHttpClientFactory HttpFactory

<h3>FormBuilder</h3>

@code {
    class Question
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Label { get; set; } = string.Empty;
        public string Target { get; set; } = "firstName";
        public string Value { get; set; } = string.Empty;
    }

    class PreviewRequest
    {
        public string Subject { get; set; } = "self";
        public string DirectReportId { get; set; } = string.Empty;
        public List<Question> Questions { get; set; } = new();
        public string FileName { get; set; } = string.Empty;
    }

    class PreviewViewModel
    {
        public string Subject { get; set; }
        public string Name { get; set; }
        public string Email { get; set; }
        public string Bio { get; set; }
    }

    [Parameter] public string DirectReportJason { get; set; } = "[]";
    [Parameter] public string UserGivenName { get; set; } = string.Empty;
    [Parameter] public string UserSurname { get; set; } = string.Empty;
    [Parameter] public string UserEmail { get; set; } = string.Empty;

    List<Question> questions = new();
    List<JsonElement> directReports = new();
    string currentSubject = "self";
    JsonElement? selectedDirectReport = null;
    PreviewViewModel serverPreview = null;
    string saveFilename = string.Empty;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(DirectReportJason))
        {
            try
            {
                directReports = JsonSerializer.Deserialize<List<JsonElement>>(DirectReportJason);
            }
            catch
            {
                directReports = new();
            }

            questions = new List<Question>();
        }
    }

    void AddQuestion()
    {
        questions.Add(new Question
        { 
            Label = "New Question",
            Target = "firstName"
        });
    }

    void RemoveQuestion(Question question) => questions.Remove(question);

    void SetSubject(string subject)
    {
        currentSubject = subject;
        if (subject == "self") selectedDirectReport = null;
    }

    void SetDirectReport(ChangeEventArgs eventArgs)
    {
        var id = eventArgs.Value?.ToString();
        if (string.IsNullOrEmpty(id))
        { 
            selectedDirectReport = null;
            return;
        }
        selectedDirectReport = directReports.FirstOrDefault(directReport => directReport.TryGetProperty("id", out var idProperty) && idProperty.GetString() == id);
    }

    async Task FetchServerPreviewAsync()
    {
        var client = HttpFactory.CreateClient("server");
        var payload = new PreviewRequest
        {
            Subject = currentSubject,
            DirectReportId = selectedDirectReport.HasValue && selectedDirectReport.Value.TryGetProperty("id", out var idProperty) ? idProperty.GetString() : null,
            Questions = questions
        };

        var response = await client.PostAsJsonAsync("/Home/Preview", payload);
        if (!response.IsSuccessStatusCode)
        {
            serverPreview = new PreviewViewModel
            {
                Name = "Preview Failed",
                Email = string.Empty,
                Bio = await response.Content.ReadAsStringAsync()
            };
        }

        ComputeLocalPreview();

        void ComputeLocalPreview()
        {
            string baseFirstName = UserGivenName, baseLastName = UserSurname, baseEmail = UserEmail;
            if (currentSubject == "direct" && selectedDirectReport.HasValue)
            {
                if (selectedDirectReport.Value.TryGetProperty("displayName", out var display_Name))
                {
                    var parts = display_Name.GetString().Split(' ', 2);
                    baseFirstName = parts.Length > 0 ? parts[0] : baseFirstName;
                    baseLastName = parts.Length > 1 ? parts[1] : baseLastName;
                }
                if (selectedDirectReport.Value.TryGetProperty("mail", out var mail))
                {
                    baseEmail = string.IsNullOrEmpty(mail.GetString()) ? baseEmail : mail.GetString();
                }
            }

            var finalFirst = baseFirstName;
            var finalLast = baseLastName;
            var finalEmail = baseEmail;
            var finalBio = "";
            foreach (var question in questions)
            {
                if (string.IsNullOrWhiteSpace(question.Value)) continue;
                switch (question.Target)
                {
                    case "firstName":
                        finalFirst = question.Value;
                        break;
                    case "lastName":
                        finalLast = question.Value;
                        break;
                    case "email":
                        finalEmail = question.Value;
                        break;
                    case "bio":
                        finalBio = question.Value;
                        break;
                }
            }

            serverPreview = new PreviewViewModel
            {
                Subject = currentSubject,
                Name = $"{finalFirst} {finalLast}".Trim(),
                Email = finalEmail,
                Bio = finalBio
            };
        }

        async Task SaveAsync()
        {
            var client = HttpFactory.CreateClient("server");
            var payload = new PreviewRequest
            {
                Subject = currentSubject,
                DirectReportId = selectedDirectReport.HasValue && selectedDirectReport.Value.TryGetProperty("id", out var idProperty) ? idProperty.GetString() : null,
                Questions = questions,
                FileName = saveFilename
            };

            var response = await client.PostAsJsonAsync("/Home/Save", payload);
            if (response.IsSuccessStatusCode)
            {
                var jason = await response.Content.ReadFromJsonAsync<JsonElement?>();
                serverPreview = new PreviewViewModel
                {
                    Name = "Save",
                    Email = jason?.GetProperty("WebUrl").GetString() ?? "Saved",
                    Bio = ""
                };
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                serverPreview = new PreviewViewModel
                {
                    Name = "Save Failed",
                    Email = text,
                    Bio = ""
                };
            }
        }       
    }
}

<div class="row">
    <div class="col-6">
        <h5>Questions</h5>

        <div class="mb-2">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" id="subjectSelf" onclick="@(() => SetSubject("self"))" checked="@("self"==currentSubject)" />
                <label class="form-check-label" for="subjectSelf">For me (@UserGivenName @UserSurname)</label>
            </div>
            @if (directReports.Any())
            {
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" id="subjectDirect" onclick="@(() => SetSubject("direct"))" checked="@("direct"==currentSubject)" />
                    <label class="form-check-label" for="subjectDirect">For my direct report</label>
                </div>
            }
        </div>

        @if (directReports.Any())
        {
            <select class="form-select mb-3" @onchange="SetDirectReport" disabled="@(currentSubject != "direct")">
                <option value="">-- Select a direct report --</option>
                @foreach (var directReport in directReports)
                {
                    var id = directReport.GetProperty("id").GetString();
                    var displayName = directReport.GetProperty("displayName").GetString();
                    <option value="@id">
                        @displayName
                    </option>
                }
            </select>
        }

        <div>
            @foreach (var question in questions)
            {
                <div class="mb-2 border round p-2">
                    <div class="d-flex">
                        <input class="form-control me-2" @bind="question.Label" />
                        <select class="form-select me-2" style="width:160px" @bind="question.Target">
                            <option value="firstName">First Name</option>
                            <option value="lastName">Last Name</option>
                            <option value="email">Email</option>
                            <option value="bio">Bio</option>
                        </select>
                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveQuestion(question))">Remove</button>
                    </div>
                    <input class="form-control mt-2" placeholder="Type answer..." @bind="question.Value" />
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <h5>Preview</h5>
            @if (serverPreview == null)
            {
                <div class="text-muted">No preview yet</div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <h4>@(string.IsNullOrWhiteSpace(serverPreview.Name) ? "No Name provided" : serverPreview.Name)</h4>
                        <p><strong>Email:</strong> @(string.IsNullOrWhiteSpace(serverPreview.Email) ? "No Email provided" : serverPreview.Email)</p>
                        <p><strong>Summary:</strong></p>
                        <div class="border rounded p-2">@((MarkupString)System.Net.WebUtility.HtmlEncode(serverPreview.Bio).Replace("\n", "<br/>"))</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>